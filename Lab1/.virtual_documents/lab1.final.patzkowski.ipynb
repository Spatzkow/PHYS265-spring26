t= 15.8 #s
m_o= 2.8e6 #kg
m_f=7.5e5 #kg
g=9.8 #m/s^2
v_e= 2.4e3 #m/s
def velocity(t):
    """
   t= time a float or integer
   m_o= float or integer, wet mass
   m_f= float or integer, dry mass of rocket when all of the fuel is burned out
   g= float, constant, 9.8 m/s^2
   m= float or integer, burn fuel rate
   v_e= float or intege, fuel exhaust velocity
       """
    m_t= m_o-m*t
    return  v_e*np.log(m_o/m_t)-g*t #change in velocity
    






