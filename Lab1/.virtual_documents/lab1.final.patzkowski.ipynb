#have to make a def function, identify parameters M1, m2, (x1,y1), (x2,y2)
#function needs to return gravitational force components Fx and Fy
#the return values acredited to experiencing the mass m2 from having force exerted on it by M1

def gravitational_force (M1:(float, int), m2:(float, int), x1:(float,int), y1:(float,int), x2:(float,int), y2:(float,int)):
    """
    M1 (float,int): produces gravitational field
    m2 (float,int): test mass, mass that experiences force of M2
    x1,y1(float,int): cartesian location of M1 body
    x2,y2 (float,int): cartesian location of m2 body
    """
    radius= np.sqrt((x2-x1)^2 + (y2-y1)^2)

    epsilon=1e6
    F_21= -G *(M1*m2)/r**3   #the reason why r**3 is because of the unit vector r 

    delta_x = x2-x1
    delta_y = y2-y1

    Fx= F_21 * delta_x
    Fy= F_21 * delta_y

    return Fx, Fy





