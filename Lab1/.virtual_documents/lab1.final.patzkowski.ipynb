def Earth (G:float, M:float, xM:float, yM:float, x:float, y:float)-> float:
    """
    Arguments:
    G(float): gravity can't be less than 0
    M(float): mass
    xM, yM (float): cartesian location of the mass
    x,y (float): location of distant evaluation point
    """
    if not isinstance (G,(float,int)):
        raise TypeError(f"G must be a numerical value")
    elif G<=0:
        raise ValueError(f"G should not be a value less than or equal to zero")

    if not isinstance (M,(float, int)):
        raise TypeError(f"M must be a numerical value")
    elif M<=0:
        raise ValueError(f"M should not be a value less than or equal to zero")

    if not isinstance(xM, (float,int)):
        raise TypeError(f"xM must be a numerical value")
    if not isinstace(yM, (float,int)):
        raise TypeError(f"yM must be a numerical value")
    if not isinstance (x, (float,int)):
        raise TypeError(f"x must be a numerical value")
    if not isinstance (y,(float,int)):
        raise TypeError(f"y must be a numerical value")

    r=np.sqrt((x-xM)**2 + (y-yM)**2)
    if r==0:
        raise ValueError(f"gravitational potential can't have r=0")

    gravitational_potential= -G*M/r

    if not np.isfinite(gravitational_potential):
        raise ValueError(f"gravitational potential must be finite")

    return gravitational_potential






