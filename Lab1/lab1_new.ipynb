    "#add logarithmic colorbar\n",
    "#location of Earth has to be a black circle, moon has to have a black square\n",
    "#create a legend\n",
    "\n",
    "G= 6.67e-11 #m^3/kg/s^2\n",
    "M_E= 5.9e24 #kg\n",
    "M_M=7.3e22 #kg\n",
    "d_EM=3.8e8 #m\n",
    "Apollo_CM_mass= 5500 #kg\n",
    "\n",
    "\n",
    "x_vals=np.linspace(-1.5*d_EM, 1.5*d_EM, 200)\n",
    "y_vals=np.linspace(-1.5*d_EM, 1.5*d_EM,200)\n",
    "x,y=np.meshgrid(x_vals,y_vals)\n",
    "Radius_E= np.sqrt(x**2+y**2)\n",
    "Radius_M= np.sqrt((x-d_EM/np.sqrt(2))**2+(y-d_EM/np.sqrt(2))**2)\n",
    "GP= -(G*M_E)/Radius_E - (G*M_M)/Radius_M\n",
    "\n",
    "epsilon=1e6 #km\n",
    "def r_E(x,y):\n",
    "    return np.where(x==0, y==0, epsilon, Radius_E)\n",
    "def r_M(x,y):\n",
    "    return np.where(x==d_EM/np.sqrt(2), y==d_EM/np.sqrt(2),epsilon, Radius_M)\n",
    "\n",
    "#have to put in the values into the force equations so I have Apollo 11 command module accounted for\n",
    "F_Earth = -G*(M_E * Apollo_CM_mass)/Radius_E**2\n",
