    "from scipy.integrate import quad\n",
    "\n",
    "m_o=2.8e6 #kg\n",
    "v_e=2.4e3 #m/s\n",
    "g=9.8#m/s^2\n",
    "m=1.3e4 #kg/s\n",
    "m_t= m_o-m*t\n",
    "T=(m_o-m_f)/m\n",
    "delta_v= v_e*np.log(m_o/m_t)-g*t\n",
    "altitude, err= quad(velocity, 0,T)\n",
    "\n",
    "print(altitude, err)\n",
    "print(T)"
